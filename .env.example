# Copy this file to `.env` and fill in real values. `.env` is git-ignored —
# never commit real secrets.

# Required: your Anthropic API key (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=

# Required: the target GitHub repository to analyze. This tool is repo-agnostic —
# there is no default baked into the code. The value below is only an EXAMPLE,
# the assignment's target repo; point it at any public Java/Spring repo you like.
REPO_URL=https://github.com/codejsha/spring-rest-sakila

# Optional: git branch/tag/ref to check out. Defaults to "main" if unset.
REPO_REF=main

# Optional overrides — see `python main.py --help` for the full list and
# CLI equivalents. CLI flags always win over these environment variables.
# MODEL=claude-haiku-4-5
# BATCH_SIZE=6
